<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.platform.ops.mapper.DeployStrategyMapper">
    <!-- 可根据需要添加复杂SQL -->
    <select id="findByAppIdAndEnvId" resultType="com.platform.ops.entity.DeployStrategyEntity">
        SELECT *
        FROM deploy_strategies
        WHERE app_id = #{appId}
          AND env_id = #{envId} LIMIT 1
    </select>
</mapper>