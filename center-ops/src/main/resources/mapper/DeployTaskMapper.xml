<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.platform.ops.mapper.DeployTaskMapper">
    <!-- 可根据需要添加复杂SQL -->
    <update id="update" parameterType="com.platform.ops.entity.DeployTaskEntity">
        UPDATE deploy_tasks
        SET status              = #{status},
            rollback_to_version = #{rollbackToVersion},
            updated_at          = NOW()
        WHERE id = #{id}
    </update>
</mapper>